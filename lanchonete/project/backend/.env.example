# ── Banco de dados ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lanchonete

# ── JWT ──────────────────────────────────────────────────────
SECRET_KEY=troque-por-um-valor-seguro-gerado-com-openssl-rand-hex-32
